# ============================================================
# Memora — Environment Template
# ============================================================
#
# HOW TO USE
#
# 1. Copy:
#       cp .env.example .env
#
# 2. Replace placeholders with real values
#
# 3. Start backend services
#
# 4. backend/config.py is the ONLY place
#    environment variables are read.
#
# ============================================================



# ============================================================
# HuggingFace
# ============================================================

# REQUIRED — get from https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_token_here



# ============================================================
# PostgreSQL
# Primary relational memory storage
# ============================================================

# Database host
POSTGRES_HOST=localhost

# Database port
POSTGRES_PORT=5432

# Database name
POSTGRES_DB=memory_ai

# REQUIRED — get from PostgreSQL setup
POSTGRES_USER=admin

# REQUIRED — get from PostgreSQL setup
POSTGRES_PASSWORD=password

# Async SQLAlchemy connection URL
POSTGRES_URL=postgresql+asyncpg://admin:password@localhost/memory_ai



# ============================================================
# Redis
# Session + cache layer
# ============================================================

# Redis host
REDIS_HOST=localhost

# Redis port
REDIS_PORT=6379

# Redis connection URL
REDIS_URL=redis://localhost:6379



# ============================================================
# Qdrant
# Cold vector memory storage
# ============================================================

# Qdrant host
QDRANT_HOST=localhost

# Qdrant port
QDRANT_PORT=6333

# Qdrant API URL
QDRANT_URL=http://localhost:6333



# ============================================================
# Neo4j
# Knowledge graph storage
# ============================================================

# Neo4j host
NEO4J_HOST=localhost

# Neo4j bolt port
NEO4J_PORT=7687

# Neo4j connection URI
NEO4J_URI=bolt://localhost:7687

# REQUIRED — get from Neo4j setup
NEO4J_USER=neo4j

# REQUIRED — get from Neo4j setup
NEO4J_PASSWORD=password



# ============================================================
# Supabase Authentication
# ============================================================

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# REQUIRED — get from Supabase project settings
SUPABASE_ANON_KEY=your_anon_key

# REQUIRED — get from Supabase Auth settings
SUPABASE_JWT_SECRET=your_jwt_secret



# ============================================================
# Model Configuration
# ============================================================

# Embedding model
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5

# CRITICAL:
# must be 1024 for bge-large-en-v1.5
# do NOT change to 1536
EMBEDDING_DIMS=1024

# Named entity recognition
NER_MODEL_NAME=gliner-community/gliner_large-v2.5

# Classification model
CLASSIFICATION_MODEL_NAME=facebook/bart-large-mnli

# Retrieval reranker
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# Natural language inference
NLI_MODEL_NAME=cross-encoder/nli-deberta-v3-large

# Summarization model
SUMMARIZER_MODEL_NAME=facebook/bart-large-cnn

# Primary generation model
LLM_MODEL_NAME=meta-llama/Llama-3.1-70B-Instruct

# Fast generation model
LLM_FAST_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3

# Optional — defaults to ./.model_cache
MODEL_CACHE_DIR=./.model_cache

# Options:
# cpu | cuda | mps | auto
# auto detects best available
DEVICE=cpu



# ============================================================
# Application Configuration
# ============================================================

# Optional — defaults to development
APP_ENV=development

# Optional — defaults to INFO
LOG_LEVEL=INFO

# Optional — defaults to 3600
HOT_CACHE_TTL_SECONDS=3600

# Optional — defaults to 30
WARM_STORE_DAYS=30

# Optional — defaults to 0.4
IMPORTANCE_THRESHOLD=0.4

# Optional — defaults to 0.01
DECAY_RATE=0.01

# Optional — defaults to 8
MAX_CONTEXT_MEMORIES=8

# Optional — defaults to 15
MAX_RETRIEVAL_CANDIDATES=15

# Optional — defaults to 20
MAX_SESSION_MESSAGES=20



# ============================================================
# Frontend (Next.js 14)
# Safe for browser exposure
# ============================================================

# Frontend → Backend URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public Supabase URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public Supabase anonymous key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key



# ============================================================
# SECURITY NOTE
# ============================================================

# Never commit .env to version control —
# only commit .env.example